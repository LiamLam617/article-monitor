# Article Monitor - Environment variables
# Copy to .env and set values. Source: monitor/config.py

# --- Logging ---
# Optional debug log file path (leave empty to disable)
# ARTICLE_MONITOR_DEBUG_LOG=
# Log level: DEBUG/INFO/WARNING/ERROR/CRITICAL (default: INFO)
# ARTICLE_MONITOR_LOG_LEVEL=INFO
#
# Enable file logging (default: 0)
# ARTICLE_MONITOR_LOG_TO_FILE=1
#
# Optional explicit file path (default: article-monitor/logs/article-monitor.log)
# ARTICLE_MONITOR_LOG_FILE=
#
# Console output format: text or json (default: text)
# ARTICLE_MONITOR_LOG_FORMAT_CONSOLE=text
#
# File output format: text or json (default: json)
# ARTICLE_MONITOR_LOG_FORMAT_FILE=json
#
# Rotating file settings (default: 50MB, 10 backups)
# ARTICLE_MONITOR_LOG_MAX_BYTES=52428800
# ARTICLE_MONITOR_LOG_BACKUP_COUNT=10
#
# Non-blocking queue logging (default: 1)
# ARTICLE_MONITOR_LOG_QUEUE_ENABLED=1
# ARTICLE_MONITOR_LOG_QUEUE_MAXSIZE=10000

# --- Crawl ---
# Crawl interval in hours (default: 6)
# CRAWL_INTERVAL_HOURS=6
# Request timeout in seconds (default: 60)
# CRAWL_TIMEOUT=60
# Concurrency (1-10, default: 5)
# CRAWL_CONCURRENCY=5
# Delay between requests in seconds (default: 1)
# CRAWL_DELAY=1
# Max concurrent requests per domain; 0 = no limit (default: 1)
# CRAWL_CONCURRENCY_PER_DOMAIN=1
# Round-robin by site: True/False (default: True)
# CRAWL_INTERLEAVE_BY_SITE=True
# Min delay between requests to same domain in seconds; 0 = no limit (default: 0)
# CRAWL_MIN_DELAY_PER_DOMAIN=0
# Retries
# CRAWL_MAX_RETRIES=10
# CRAWL_RETRY_DELAY=2
# CRAWL_RETRY_BACKOFF=1.5
# CRAWL_RETRY_MAX_DELAY=30
# CRAWL_RETRY_JITTER=True
# CRAWL_RETRY_NETWORK_MAX=10
# CRAWL_RETRY_PARSE_MAX=3
# CRAWL_RETRY_SSL_MAX=5
# CRAWL_RETRY_SSL_DELAY=5
#
# Result-based retry passes for crawl_urls_for_results (default: 1)
# - 0: no retry pass (only first attempt)
# - 1: retry once for retryable failures
# RESULT_RETRY_EXTRA_PASSES=1

# --- Anti-scraping ---
# ANTI_SCRAPING_ENABLED=True
# ANTI_SCRAPING_ROTATE_UA=True
# ANTI_SCRAPING_RANDOM_DELAY=True
# ANTI_SCRAPING_STEALTH_MODE=True
# ANTI_SCRAPING_MIN_DELAY=1.0
# ANTI_SCRAPING_MAX_DELAY=5.0
# ANTI_SCRAPING_UA_ROTATION_MIN=10
# ANTI_SCRAPING_UA_ROTATION_MAX=30

# --- Flask ---
# FLASK_HOST=127.0.0.1
# FLASK_PORT=5001
# FLASK_DEBUG=False

# --- Platform whitelist ---
# Comma-separated list; empty = use default whitelist
# Example: ALLOWED_PLATFORMS=juejin,csdn,cnblog
# ALLOWED_PLATFORMS=

# --- Feishu Bitable (optional) ---
# Required for POST /api/bitable/sync (or pass app_token/table_id in request body)
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_BITABLE_APP_TOKEN=
# FEISHU_BITABLE_TABLE_ID=
# Bitable field names (defaults shown)
# FEISHU_BITABLE_FIELD_URL=发布链接
# FEISHU_BITABLE_FIELD_TOTAL_READ=总阅读量
# FEISHU_BITABLE_FIELD_READ_24H=24小时阅读量
# FEISHU_BITABLE_FIELD_READ_72H=72小时总阅读量
# FEISHU_BITABLE_FIELD_ERROR=失败原因
# Max length for error message written to Bitable (100-500, default: 200)
# FEISHU_BITABLE_ERROR_MESSAGE_MAX_LEN=200
